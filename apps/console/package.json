{
  "name": "@probo/console",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "relay": "npx relay-compiler --output quiet-with-errors",
    "relay:watch": "npx relay-compiler --output quiet-with-errors --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "@probo/react-lazy": "^0.1.0",
